# IngredParse — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_USER=
SUPABASE_PASSWORD=
SUPABASE_DATABASE=

# ── OCR Engine ────────────────────────────────────────────────────────────────
# Options: gpt4vision (production) | easyocr (development, free, local)
OCR_ENGINE=easyocr

# ── Development Flags ─────────────────────────────────────────────────────────
# Set to true to skip OCR and use a static text file (speeds up local testing)
USE_STATIC_TEXT=false
# Set to true to skip GPT-4 fallback and return mock data
USE_STATIC_FALLBACK=false

# ── Optional / Unused in current MVP ──────────────────────────────────────────
# MISTRAL_API=
# GOOGLE_SEARCH_API_KEY=
# USDA_FOODDATA_API_KEY=
# TEST_IMAGE_PATH=
